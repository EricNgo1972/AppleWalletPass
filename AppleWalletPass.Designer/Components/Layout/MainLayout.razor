@inherits LayoutComponentBase
@implements IDisposable
@inject ThemeState ThemeState

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Class="designer-appbar">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6">Apple Wallet Pass Designer</MudText>
        <MudSpacer />
        <MudTooltip Text="Toggle light and dark mode">
            <MudIconButton
                Icon="@(ThemeState.IsDarkMode ? Icons.Material.Filled.DarkMode : Icons.Material.Filled.LightMode)"
                Color="Color.Inherit"
                OnClick="ToggleTheme" />
        </MudTooltip>
        <MudChip T="string" Value="@("Blazor Server")" Variant="Variant.Outlined" Color="Color.Info">Blazor Server</MudChip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" Elevation="1" Class="designer-drawer">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="designer-main">
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-4 pa-md-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    protected override void OnInitialized()
    {
        ThemeState.Changed += OnThemeChanged;
    }

    public void Dispose()
    {
        ThemeState.Changed -= OnThemeChanged;
    }

    private void ToggleDrawer()
        => _drawerOpen = !_drawerOpen;

    private void ToggleTheme()
        => ThemeState.Toggle();

    private void OnThemeChanged()
        => InvokeAsync(StateHasChanged);
}
