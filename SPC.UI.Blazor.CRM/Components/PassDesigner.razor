@inject HttpClient Http
@inject IJSRuntime JS
@using System.Net.Http.Headers

<MudGrid>
    <MudItem xs="12" xl="7">
        <MudPaper Class="pa-4 pass-editor-panel" Elevation="0">
            <MudStack Spacing="3">
                <MudStack Spacing="1">
                    <MudText Typo="Typo.overline" Class="mud-text-secondary">Pass Details</MudText>
                    <MudText Typo="Typo.h4">Design your Apple Wallet pass</MudText>
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(StatusMessage))
                {
                    <MudAlert Severity="@StatusSeverity" Variant="Variant.Outlined">@StatusMessage</MudAlert>
                }

                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Pass type</MudText>
                    <MudChipSet T="DesignerPassType" SelectionMode="SelectionMode.SingleSelection" CheckMark="false" SelectedValue="@Model.PassType" SelectedValueChanged="OnPassTypeChanged">
                        <MudChip T="DesignerPassType" Value="DesignerPassType.Boarding">Boarding</MudChip>
                        <MudChip T="DesignerPassType" Value="DesignerPassType.Event">Event</MudChip>
                        <MudChip T="DesignerPassType" Value="DesignerPassType.Coupon">Coupon</MudChip>
                        <MudChip T="DesignerPassType" Value="DesignerPassType.StoreCard">Store card</MudChip>
                    </MudChipSet>
                </div>

                <MudTextField @bind-Value="Model.OrganizationName" Label="Organization" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="Model.Title" Label="Pass title" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="Model.Subtitle" Label="Subtitle" Variant="Variant.Outlined" />
                <MudTextField @bind-Value="Model.SerialNumber" Label="Serial number" Variant="Variant.Outlined" />

                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Background color</MudText>
                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                        @foreach (var color in Palette)
                        {
                            <MudIconButton
                                Class="@($"color-swatch {(Model.BackgroundColor == color ? "selected" : string.Empty)}")"
                                Style="@($"background:{color};")"
                                Icon="@Icons.Material.Filled.Circle"
                                Color="Color.Inherit"
                                OnClick="@(() => Model.BackgroundColor = color)" />
                        }
                    </MudStack>
                </div>

                <MudGrid>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3 asset-card" Outlined="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">Icon</MudText>
                                <InputFile OnChange="@(args => UploadAssetAsync(args, DesignerAssetSlot.Icon))" accept="image/*" />
                                <MudText Typo="Typo.caption">@GetAssetName(Model.IconAsset, "Upload icon")</MudText>
                                <MudText Typo="Typo.caption" Class="asset-help">
                                    Used by Wallet in list/stack views and notifications, not as the main face image.
                                </MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3 asset-card" Outlined="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">Logo</MudText>
                                <InputFile OnChange="@(args => UploadAssetAsync(args, DesignerAssetSlot.Logo))" accept="image/*" />
                                <MudText Typo="Typo.caption">@GetAssetName(Model.LogoAsset, "Optional logo")</MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" md="4">
                        <MudPaper Class="pa-3 asset-card" Outlined="true">
                            <MudStack Spacing="1">
                                <MudText Typo="Typo.subtitle2">Background</MudText>
                                <InputFile OnChange="@(args => UploadAssetAsync(args, DesignerAssetSlot.Background))" accept="image/*" />
                                <MudText Typo="Typo.caption">@GetAssetName(Model.BackgroundAsset, "Optional background")</MudText>
                            </MudStack>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <div>
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Custom fields</MudText>
                    <MudStack Spacing="2">
                        @foreach (var field in Model.Fields)
                        {
                            <MudGrid>
                                <MudItem xs="5">
                                    <MudTextField @bind-Value="field.Label" Placeholder="Label" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="5">
                                    <MudTextField @bind-Value="field.Value" Placeholder="Value" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="2" Class="d-flex align-center justify-center">
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="@(() => RemoveField(field))" />
                                </MudItem>
                            </MudGrid>
                        }
                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="AddField">Add field</MudButton>
                    </MudStack>
                </div>

                <div>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                        <MudText Typo="Typo.subtitle2">Back fields</MudText>
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Shown in Wallet detail view</MudText>
                    </MudStack>

                    <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                        <MudChip T="string" Variant="Variant.Outlined" OnClick='@(() => AddBackFieldPreset("Website", "https://example.com/pass", BackFieldType.Link))'>Website</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" OnClick='@(() => AddBackFieldPreset("Support Email", "support@example.com", BackFieldType.Link))'>Support email</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" OnClick='@(() => AddBackFieldPreset("Terms", "Valid through Apr 30. One redemption per member.", BackFieldType.MultilineText))'>Terms</MudChip>
                        <MudChip T="string" Variant="Variant.Outlined" OnClick='@(() => AddBackFieldPreset("Address", "123 Main Street\nNew York, NY 10001", BackFieldType.MultilineText))'>Address</MudChip>
                    </MudStack>

                    <MudStack Spacing="2">
                        @foreach (var field in Model.BackFields)
                        {
                            <MudPaper Class="pa-3 asset-card" Outlined="true">
                                <MudGrid>
                                    <MudItem xs="12" md="3">
                                        <MudSelect T="BackFieldType" @bind-Value="field.Type" Label="Type" Variant="Variant.Outlined" Margin="Margin.Dense">
                                            <MudSelectItem T="BackFieldType" Value="BackFieldType.PlainText">Plain text</MudSelectItem>
                                            <MudSelectItem T="BackFieldType" Value="BackFieldType.Link">Link</MudSelectItem>
                                            <MudSelectItem T="BackFieldType" Value="BackFieldType.MultilineText">Multiline</MudSelectItem>
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="12" md="3">
                                        <MudTextField @bind-Value="field.Label" Placeholder="Label" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                    </MudItem>
                                    <MudItem xs="10" md="5">
                                        <MudTextField @bind-Value="field.Value" Placeholder="Value" Variant="Variant.Outlined" Margin="Margin.Dense" Lines="@(field.Type == BackFieldType.MultilineText ? 3 : 1)" />
                                    </MudItem>
                                    <MudItem xs="2" md="1" Class="d-flex align-center justify-center">
                                        <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Error" OnClick="@(() => RemoveBackField(field))" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                        <MudButton Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Add" OnClick="AddBackField">Add back field</MudButton>
                    </MudStack>
                </div>

                <MudSelect T="DesignerBarcodeStyle" @bind-Value="Model.BarcodeStyle" Label="Barcode style" Variant="Variant.Outlined">
                    <MudSelectItem T="DesignerBarcodeStyle" Value="DesignerBarcodeStyle.QrCode">QR code</MudSelectItem>
                    <MudSelectItem T="DesignerBarcodeStyle" Value="DesignerBarcodeStyle.Pdf417">PDF417</MudSelectItem>
                    <MudSelectItem T="DesignerBarcodeStyle" Value="DesignerBarcodeStyle.Aztec">Aztec</MudSelectItem>
                    <MudSelectItem T="DesignerBarcodeStyle" Value="DesignerBarcodeStyle.Code128">Code 128</MudSelectItem>
                    <MudSelectItem T="DesignerBarcodeStyle" Value="DesignerBarcodeStyle.None">None</MudSelectItem>
                </MudSelect>

                @if (Model.BarcodeStyle != DesignerBarcodeStyle.None)
                {
                    <MudTextField
                        @bind-Value="Model.BarcodeMessage"
                        Label="Barcode payload"
                        Variant="Variant.Outlined"
                        Placeholder="Defaults to serial number if empty" />
                    <MudTextField
                        @bind-Value="Model.BarcodeAltText"
                        Label="Barcode caption"
                        Variant="Variant.Outlined"
                        Placeholder="Shown below the code; defaults to serial number if empty" />
                }

                <MudAlert Severity="Severity.Info" Variant="Variant.Text">
                    Configure the certificate and Wallet identifiers in <strong>Signing Settings</strong>, then return here to generate a signed pass.
                </MudAlert>
            </MudStack>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" xl="5">
        <MudPaper Class="pa-4 preview-panel" Elevation="0">
                <MudStack Spacing="3">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="preview-panel-header">
                        <div>
                            <MudText Typo="Typo.overline" Class="preview-panel-kicker">Preview</MudText>
                            <MudText Typo="Typo.h5" Class="preview-panel-title">Live pass preview</MudText>
                        </div>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Download" Disabled="@IsDownloading" OnClick="DownloadAsync">
                            @(IsDownloading ? "Generating..." : "Download .pkpass")
                        </MudButton>
                    </MudStack>

                    <MudChipSet T="PreviewMode" SelectionMode="SelectionMode.SingleSelection" CheckMark="false" SelectedValue="@CurrentPreviewMode" SelectedValueChanged="OnPreviewModeChanged">
                        <MudChip T="PreviewMode" Value="PreviewMode.Front">Front</MudChip>
                        <MudChip T="PreviewMode" Value="PreviewMode.Back">Back detail</MudChip>
                    </MudChipSet>

                    <div class="wallet-preview-viewport">
                        <PassPreview Model="Model" ShowBack="@IsBackPreview" />
                    </div>
                </MudStack>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    [Parameter]
    public PassDesignerModel Model { get; set; } = new();

    [Parameter]
    public string? StatusMessage { get; set; }

    [Parameter]
    public Severity StatusSeverity { get; set; } = Severity.Info;

    private static readonly string[] Palette =
    [
        "#1D2B53",
        "#0A3D62",
        "#1B4332",
        "#5A189A",
        "#9D174D",
        "#BC6C25",
        "#2B2D42",
        "#4A4E69"
    ];

    private bool IsDownloading { get; set; }

    private PreviewMode CurrentPreviewMode { get; set; }

    private bool IsBackPreview => CurrentPreviewMode == PreviewMode.Back;

    private async Task UploadAssetAsync(InputFileChangeEventArgs args, DesignerAssetSlot slot)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        await using var stream = file.OpenReadStream(10_000_000);
        using var content = new MultipartFormDataContent();
        using var fileContent = new StreamContent(stream);
        fileContent.Headers.ContentType = new MediaTypeHeaderValue(string.IsNullOrWhiteSpace(file.ContentType) ? "application/octet-stream" : file.ContentType);
        content.Add(fileContent, "file", file.Name);

        var response = await Http.PostAsync($"api/assets/upload/{slot}", content);
        if (!response.IsSuccessStatusCode)
        {
            SetStatus(await ExtractErrorAsync(response));
            return;
        }

        var uploaded = await response.Content.ReadFromJsonAsync<AssetUploadResponse>();
        if (uploaded is null)
        {
            SetStatus("The upload completed but no asset response was returned.");
            return;
        }

        var target = slot switch
        {
            DesignerAssetSlot.Icon => Model.IconAsset,
            DesignerAssetSlot.Logo => Model.LogoAsset,
            DesignerAssetSlot.Background => Model.BackgroundAsset,
            _ => Model.IconAsset
        };

        target.Token = uploaded.Token;
        target.FileName = uploaded.FileName;
        target.PreviewUrl = uploaded.PreviewUrl;
        target.ContentType = uploaded.ContentType;
        SetStatus($"{slot} image uploaded.", Severity.Success);
    }

    private void AddField()
        => Model.Fields.Add(new PassFieldInputModel());

    private void AddBackField()
        => Model.BackFields.Add(new BackFieldInputModel());

    private void RemoveField(PassFieldInputModel field)
    {
        if (Model.Fields.Count == 1)
        {
            field.Label = string.Empty;
            field.Value = string.Empty;
            return;
        }

        Model.Fields.Remove(field);
    }

    private void RemoveBackField(BackFieldInputModel field)
    {
        if (Model.BackFields.Count == 1)
        {
            field.Label = string.Empty;
            field.Value = string.Empty;
            field.Type = BackFieldType.PlainText;
            return;
        }

        Model.BackFields.Remove(field);
    }

    private Task OnPassTypeChanged(DesignerPassType passType)
    {
        Model.PassType = passType;

        switch (passType)
        {
            case DesignerPassType.Boarding:
                Model.Title = "Boarding Pass";
                Model.Subtitle = "Flight Ready";
                Model.BarcodeMessage ??= "https://example.com/boarding/PASS";
                Model.BarcodeAltText ??= Model.SerialNumber;
                Model.Fields =
                [
                    new() { Label = "From", Value = "JFK" },
                    new() { Label = "To", Value = "LAX" }
                ];
                Model.BackFields =
                [
                    new() { Label = "Boarding time", Value = "10:25 AM", Type = BackFieldType.PlainText },
                    new() { Label = "Gate info", Value = "Arrive at Gate B12 30 minutes before departure.", Type = BackFieldType.MultilineText },
                    new() { Label = "Manage flight", Value = "https://example.com/boarding/PASS", Type = BackFieldType.Link }
                ];
                break;
            case DesignerPassType.Event:
                Model.Title = "Event Ticket";
                Model.Subtitle = "General Admission";
                Model.BarcodeMessage ??= "https://example.com/event/PASS";
                Model.BarcodeAltText ??= Model.SerialNumber;
                Model.Fields =
                [
                    new() { Label = "Venue", Value = "Grand Hall" },
                    new() { Label = "Date", Value = "Apr 12" }
                ];
                Model.BackFields =
                [
                    new() { Label = "Doors open", Value = "7:00 PM", Type = BackFieldType.PlainText },
                    new() { Label = "Venue address", Value = "500 Market Street\nSan Francisco, CA 94105", Type = BackFieldType.MultilineText },
                    new() { Label = "Event details", Value = "https://example.com/event/PASS", Type = BackFieldType.Link }
                ];
                break;
            case DesignerPassType.Coupon:
                Model.Title = "Member Offer";
                Model.Subtitle = "20% Off";
                Model.BarcodeMessage ??= "https://example.com/coupon/PASS";
                Model.BarcodeAltText ??= "SCAN TO REDEEM";
                Model.Fields =
                [
                    new() { Label = "Code", Value = "SAVE20" },
                    new() { Label = "ValidUntil", Value = "Apr 30" }
                ];
                Model.BackFields =
                [
                    new() { Label = "Terms", Value = "One use per customer. Cannot be combined with other offers.", Type = BackFieldType.MultilineText },
                    new() { Label = "Redeem online", Value = "https://example.com/coupon/PASS", Type = BackFieldType.Link }
                ];
                break;
            default:
                Model.Title = "Rewards Card";
                Model.Subtitle = "Gold Member";
                Model.BarcodeMessage ??= "https://example.com/member/PASS";
                Model.BarcodeAltText ??= Model.SerialNumber;
                Model.Fields =
                [
                    new() { Label = "Customer", Value = "Eric Ngo" },
                    new() { Label = "MemberSince", Value = "Apr 12" }
                ];
                Model.BackFields =
                [
                    new() { Label = "Support", Value = "support@example.com", Type = BackFieldType.PlainText },
                    new() { Label = "Member portal", Value = "https://example.com/member/PASS", Type = BackFieldType.Link },
                    new() { Label = "Benefits", Value = "Priority support\nMonthly bonus offers\nMember-exclusive events", Type = BackFieldType.MultilineText }
                ];
                break;
        }

        return Task.CompletedTask;
    }

    private Task OnPreviewModeChanged(PreviewMode mode)
    {
        CurrentPreviewMode = mode;
        return Task.CompletedTask;
    }

    private void AddBackFieldPreset(string label, string value, BackFieldType type)
        => Model.BackFields.Add(new BackFieldInputModel { Label = label, Value = value, Type = type });

    private async Task DownloadAsync()
    {
        IsDownloading = true;
        try
        {
            var response = await Http.PostAsJsonAsync("api/passes/download", new GeneratePassRequest { Design = Model });
            if (!response.IsSuccessStatusCode)
            {
                SetStatus(await ExtractErrorAsync(response));
                return;
            }

            var bytes = await response.Content.ReadAsByteArrayAsync();
            var fileName = response.Content.Headers.ContentDisposition?.FileNameStar
                ?? response.Content.Headers.ContentDisposition?.FileName?.Trim('"')
                ?? $"{Model.SerialNumber}.pkpass";

            await JS.InvokeVoidAsync("walletDesigner.downloadFileFromBytes", fileName, "application/vnd.apple.pkpass", Convert.ToBase64String(bytes));
            SetStatus("Pass generated successfully.", Severity.Success);
        }
        finally
        {
            IsDownloading = false;
        }
    }

    private void SetStatus(string message, Severity severity = Severity.Error)
    {
        StatusSeverity = severity;
        StatusMessage = message;
        StateHasChanged();
    }

    private static async Task<string> ExtractErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var payload = await response.Content.ReadFromJsonAsync<Dictionary<string, string>>();
            if (payload is not null && payload.TryGetValue("message", out var message) && !string.IsNullOrWhiteSpace(message))
            {
                return message;
            }
        }
        catch
        {
        }

        return $"Request failed with status {(int)response.StatusCode}.";
    }

    private static string GetAssetName(DesignerAssetReference asset, string fallback)
        => string.IsNullOrWhiteSpace(asset.FileName) ? fallback : asset.FileName;

    private enum PreviewMode
    {
        Front,
        Back
    }
}
